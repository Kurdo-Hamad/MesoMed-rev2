{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "uid": "mesomed-booking-funnel",
  "title": "MesoMed — Booking funnel",
  "tags": ["mesomed", "adr-0026"],
  "schemaVersion": 39,
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Bookings (24h)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(mesomed_booking_created_total[24h]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Bookings created, by channel",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (increase(mesomed_booking_created_total[$__rate_interval]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Lifecycle transitions, by action",
      "description": "confirm / checkIn / start / complete / noShow / cancel / delay / recall — the funnel body (ADR-0026).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (action) (increase(mesomed_booking_transitions_total[$__rate_interval]))",
          "legendFormat": "{{action}}"
        }
      ]
    }
  ]
}
