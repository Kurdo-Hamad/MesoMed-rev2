{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "type": "datasource",
      "pluginId": "prometheus"
    }
  ],
  "uid": "mesomed-outbox-health",
  "title": "MesoMed — Outbox health",
  "tags": ["mesomed", "adr-0026"],
  "schemaVersion": 39,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Outbox lag — age of oldest pending row (s)",
      "description": "Alert threshold: > 60s for 5m (ADR-0026). DB-derived: keeps reporting even if the dispatcher dies.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 60 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line" } }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mesomed_outbox_lag_seconds)",
          "legendFormat": "oldest pending age"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Pending backlog (rows)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "max(mesomed_outbox_pending)",
          "legendFormat": "pending rows"
        }
      ]
    }
  ]
}
