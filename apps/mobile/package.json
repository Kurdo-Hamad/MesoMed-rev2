    "@mesomed/i18n": "workspace:*",
    "@mesomed/ui-tokens": "workspace:*",
    "@tanstack/react-query": "^5.101.4",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "better-auth": "^1.6.25",
    "expo": "~57.0.8",
    "expo-constants": "~57.0.7",
    "expo-dev-client": "~57.0.9",
    "expo-device": "~57.0.1",
