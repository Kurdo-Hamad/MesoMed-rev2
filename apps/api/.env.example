# All variables are validated by src/env.ts (Zod) at boot — the API fails
# fast on anything invalid. Copy to .env for local overrides.

NODE_ENV=development
# 4000 by default: 3000 belongs to `next dev`, 8081 to the Expo dev server.
PORT=4000
LOG_LEVEL=info

# Comma-separated browser origins allowed to call this API with credentials.
# Explicit allowlist only — never a wildcard (ADR-0002).
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Postgres for Drizzle and pg-boss (required — the API refuses to boot
# without its database). Apply migrations with:
#   pnpm --filter @mesomed/db db:migrate
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mesomed

# Country attributed to requests that send no x-mesomed-country header
# (ISO 3166-1 alpha-2). Country enablement itself lives in config tables.
DEFAULT_COUNTRY=IQ

# Outbox dispatcher tuning (defaults shown; see src/env.ts).
#OUTBOX_POLL_INTERVAL_MS=1000
#OUTBOX_WORKER_POLL_INTERVAL_S=2
#OUTBOX_RETRY_LIMIT=5
#OUTBOX_RETRY_DELAY_S=2

# Fastify trustProxy (ADR-0011 F-5). REQUIRED in any production deployment
# that sits behind a reverse proxy or load balancer (the expected topology):
# left unset, every request's req.ip is the proxy's own address, so per-IP
# guardrails (identity OTP send-rate, AI triage rate limit) collapse onto
# ONE shared bucket for every caller — an accidental denial-of-service, not
# just a missed limit. Set to a comma-separated allowlist of the
# deployment's own proxy IPs/CIDRs (preferred — only those hops are
# trusted), or "true" only if this process has NO direct public access
# (every hop is trusted, so a spoofed header would otherwise be believed).
#TRUST_PROXY=

# Better Auth (Phase 2). The secret signs session tokens — required, at
# least 32 characters; generate one with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-32+-char-secret
# Public base URL of this API (used for verification links/callbacks).
BETTER_AUTH_URL=http://localhost:4000

# Optional: error tracking. Leave unset in dev/CI (Sentry no-ops).
#SENTRY_DSN=

# Optional: OTLP collector base URL. Leave unset in dev/CI (OTel no-ops).
# Base URL only — the exporter appends per-signal paths (/v1/traces) itself.
#OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Phase 7 real-channel adapters. Each is wired only when its own credentials
# are present — leave a channel's vars unset to keep it on the mock adapter
# (dev/CI default). NODE_ENV=production refuses to boot with ANY mock
# adapter still wired (see docs/runbooks/secrets-rotation-*.md).
#WHATSAPP_ACCESS_TOKEN=
#WHATSAPP_PHONE_NUMBER_ID=
#WHATSAPP_GRAPH_BASE_URL=https://graph.facebook.com/v20.0
#TWILIO_ACCOUNT_SID=
#TWILIO_AUTH_TOKEN=
#TWILIO_FROM=
#RESEND_API_KEY=
#RESEND_FROM=
#EXPO_PUSH_ACCESS_TOKEN=
#ANTHROPIC_API_KEY=
#AI_TRIAGE_MODEL=claude-haiku-4-5

# Next-day appointment reminder cron (pg-boss schedule syntax, default 06:00
# daily). pg-boss evaluates cron schedules in UTC, not local time — "0 6 * * *"
# fires at 06:00 UTC = 09:00 Baghdad time (UTC+3). Adjust the hour for the
# actual local send time you want.
#REMINDER_CRON=0 6 * * *

# Notification sender tuning (defaults shown; see src/env.ts).
#NOTIFICATION_POLL_INTERVAL_MS=5000
#NOTIFICATION_MAX_ATTEMPTS=5
#NOTIFICATION_RETRY_DELAY_S=60
